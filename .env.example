OPENAI_API_KEY=
SEMANTIC_SCHOLAR_KEY=

# --- Переключатель мок/реальный LLM (по умолчанию мок, без сети и ключей) ---
LLM_USE_REAL=false

# Вариант А: OpenAI напрямую (LLM_BASE_URL оставить пустым)
LLM_MODEL=gpt-4o-mini

# Вариант Б: OpenRouter (OpenAI-совместимый API) — раскомментировать и заполнить:
# OPENROUTER_API_KEY=
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=openai/gpt-4o-mini

# --- Мок/реальный вызов Semantic Scholar (по умолчанию мок) ---
SEMSCHOLAR_USE_REAL=false

# --- Тихий откат на мок при сбое реального вызова ---
# По умолчанию: не имеет значения в мок-режиме, ВЫКЛЮЧЕН в реальном режиме —
# сбой LLM/Semantic Scholar должен явно ронять прогон, а не незаметно
# подменяться мок-контентом. Включайте только сознательно (например, для
# публичной демонстрации, где одна нестабильная гипотеза не должна рушить
# весь прогон):
# LLM_ALLOW_MOCK_FALLBACK=true
# SEMSCHOLAR_ALLOW_MOCK_FALLBACK=true
