# виртуальное окружение и кэш
.venv/
__pycache__/
*.pyc

# локальный ChromaDB-индекс — генерируется из data/, не хранится в VCS
chroma/

# секреты — только .env.example коммитим, .env и Streamlit secrets никогда
.env
.streamlit/secrets.toml

# корпус пользователя — данные ГОКа/лаборатории не публикуются в открытый репозиторий
data/*
!data/.gitkeep

# артефакты экспорта — генерируются на лету, не коммитятся
*.docx
*.pdf
tasks.csv
tasks.json
entity_graph.html

# OS/IDE
.DS_Store
.vscode/
.idea/
